{
  "name": "htmxchat",
  "private": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:vendor && npm run build:css",
    "build:css": "tailwindcss -i ./templates/input.css -o ./static/main.css --minify",
    "build:vendor": "cp ./node_modules/htmx.org/dist/htmx.min.js ./static/htmx.min.js && cp ./node_modules/htmx-ext-ws/dist/ws.min.js ./static/ws.min.js && cp ./node_modules/htmx.org/LICENSE ./third_party/htmx.LICENSE && cp ./node_modules/htmx-ext-ws/LICENSE ./third_party/htmx-ext-ws.LICENSE",
    "format": "prettier --write 'templates/*.templ' 'static/app.js' 'README.md' '.github/**/*.yml' 'package.json'",
    "format:check": "prettier --check 'templates/*.templ' 'static/app.js' 'README.md' '.github/**/*.yml' 'package.json'"
  },
  "dependencies": {
    "htmx-ext-ws": "2.0.4",
    "htmx.org": "2.0.10"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "prettier-plugin-tailwindcss-extra-plus": "^0.3.1",
    "tailwindcss": "^4.1.11"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss-extra-plus",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": "*.templ",
        "options": {
          "parser": "tailwindcss-extra-plus"
        }
      }
    ]
  }
}
